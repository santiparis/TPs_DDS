@startuml macowins
class Prenda {
  tipo
  precioBase
  estado

  precio()
}

class Nueva {
  modificacion(precioBase)
}

class Promocion {
  valor

  modificacion(precioBase)
}

class Liquidacion {
  modificacion(precioBase)
}

interface Estado {
  modificacion(precioBase)
}

class ItemPrenda {
  prenda
  cantidad

  total()
}

class Venta {
  prendas
  fecha
  
  agregarPrenda(itemPrenda)
  monto()
}

class VentaConTarjeta {
  coeficiente
  cuotas

  monto()
  recargo()
}

class Empresa {
  ventas

  agregarVenta(venta)
  gananciasDelDia(fechaSeleccionada)
}

Nueva ..|> Estado
Promocion ..|> Estado
Liquidacion ..|> Estado

Prenda --> Estado

VentaConTarjeta --|> Venta

ItemPrenda --> Prenda

Venta --> "*" ItemPrenda

Empresa --> "*" Venta

@enduml
